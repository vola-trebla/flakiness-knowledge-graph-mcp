{
  "name": "flakiness-knowledge-graph-mcp",
  "version": "0.2.1",
  "description": "MCP server + Playwright reporter that builds a flakiness knowledge graph from test run history",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./reporter": "./dist/reporter.js"
  },
  "bin": {
    "flakiness-knowledge-graph-mcp": "./dist/index.js",
    "flakiness-graph-seed": "./dist/seed.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/seed.js",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "seed": "node dist/seed.js",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "playwright",
    "mcp",
    "flakiness",
    "testing",
    "sqlite",
    "sdet"
  ],
  "author": "vola-trebla",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "**/*.{mjs,json,md}": [
      "prettier --write"
    ],
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "mcpName": "io.github.vola-trebla/flakiness-knowledge-graph-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/vola-trebla/flakiness-knowledge-graph-mcp.git"
  }
}
